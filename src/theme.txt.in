# resolution: @W@x@H@ (generated by build.sh from src/theme.txt.in)
desktop-image: "background.png"
desktop-image-scale-method: "stretch"
desktop-color: "#1A1A1A"
title-text: ""
message-color: "#FB6F92"
message-bg-color: "#1A1A1A"

+ label {
    left = @FRAME_X@
    top = 7%
    width = @FRAME_W@
    height = @LABEL_H@
    text = "> GNU GRUB [2.12]"
    font = "LucyGrub Mono Regular @FONT_SIZE@"
    color = "#A4133C"
    align = "left"
}

+ boot_menu {
    left = @FRAME_X@
    # Five @ITEM_H@ px rows with @ITEM_SPACING@ px between them and at both frame edges.
    top = @MENU_TOP@
    width = @FRAME_W@
    height = @MENU_H@

    item_font = "LucyGrub Mono Regular @FONT_SIZE@"
    selected_item_font = "LucyGrub Mono Regular @FONT_SIZE@"
    item_color = "#A4133C"
    selected_item_color = "#FB6F92"

    icon_width = @ICON_SIZE@
    icon_height = @ICON_SIZE@
    item_icon_space = @ICON_SPACE@
    item_height = @ITEM_H@
    item_padding = 0
    item_spacing = @ITEM_SPACING@

    selected_item_pixmap_style = "select_*.png"
    scrollbar = false
}

+ image {
    left = 0
    top = 0
    width = 100%
    height = 100%
    file = "crt-overlay.png"
}
